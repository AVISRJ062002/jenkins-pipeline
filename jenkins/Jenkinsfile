pipeline {

    agent any

    options {
        timestamps()
    }

    environment {
        IMAGE_NAME = "myapp"
    }

    stages {

        stage('Checkout') {

            steps {

                echo 'Checking out source code...'

                git branch: 'main',
                url: 'https://github.com/AVISRJ062002/jenkins-pipeline.git'

            }
        }

        stage('SonarQube Analysis') {

            steps {

                script {

                    echo 'Running SonarQube analysis...'

                    def scannerHome = tool 'sonar-scanner'

                    withSonarQubeEnv('sonarqube') {

                        bat """
                        ${scannerHome}\\bin\\sonar-scanner.bat ^
                        -Dsonar.projectKey=myapp ^
                        -Dsonar.sources=./services/service1 ^
                        -Dsonar.host.url=http://localhost:9000 ^
                        -Dsonar.token=squ_b0ec8360a645f9f8652c9ec1a6ae39a3d2b2eef8
                        """

                    }
                }
            }
        }

        stage('Build Docker Image') {

            steps {

                echo 'Building Docker image...'

                bat 'docker build -t %IMAGE_NAME% ./services/service1'

            }
        }

        stage('Run Container') {

            steps {

                echo 'Deploying Docker container...'

                bat '''
                docker rm -f myapp || exit 0
                docker run -d --name myapp -p 8082:8080 myapp
                '''

            }
        }
    }

    post {

        success {

            echo 'Pipeline executed successfully!'

        }

        failure {

            echo 'Pipeline failed!'

        }

        always {

            echo 'Listing all Docker containers...'

            bat 'docker ps -a'

        }
    }
}