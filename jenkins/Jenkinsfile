pipeline {
    agent any

    options {
        skipDefaultCheckout(true)
    }

    environment {
        SERVICE1_IMAGE = "cicd-service1:latest"
        SERVICE2_IMAGE = "cicd-service2:latest"
        HOST_WORKSPACE = "/opt/jenkins_home/workspace/cicd-pipeline"
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/AVISRJ062002/jenkins-pipeline.git'
            }
        }

        stage('Build') {
            steps {
                sh '''
                    docker run --rm \
                      --memory=512m \
                      -v "$HOST_WORKSPACE:/workspace" \
                      -w /workspace/services/service1 \
                      -e MAVEN_OPTS="-Xms128m -Xmx256m" \
                      maven:3.9.9-eclipse-temurin-17 \
                      mvn -B clean package -DskipTests
                '''
                sh '''
                    docker run --rm \
                      --memory=384m \
                      -v "$HOST_WORKSPACE:/workspace" \
                      -w /workspace/services/service2 \
                      node:18 \
                      sh -c "npm install --no-fund --no-audit"
                '''
            }
        }

        stage('SonarQube Scan') {
            steps {
                withSonarQubeEnv('sonarqube') {
                    sh '''
                        docker run --rm \
                          --memory=768m \
                          -e SONAR_HOST_URL \
                          -e SONAR_AUTH_TOKEN \
                          -e MAVEN_OPTS="-Xms128m -Xmx384m" \
                          -v "$HOST_WORKSPACE:/workspace" \
                          -w /workspace/services/service1 \
                          maven:3.9.9-eclipse-temurin-17 \
                          mvn -B sonar:sonar \
                            -DskipTests \
                            -Dsonar.projectKey=service1 \
                            -Dsonar.projectName=service1
                    '''
                }
            }
        }

        stage('Docker Build') {
            steps {
                sh 'docker build -t $SERVICE1_IMAGE services/service1'
                sh 'docker build -t $SERVICE2_IMAGE services/service2'
            }
        }

        stage('Deploy') {
            steps {
                sh 'docker compose up -d --remove-orphans'
            }
        }

        stage('Health Check') {
            steps {
                sh 'bash scripts/health-check.sh http://host.docker.internal:8081'
                sh 'bash scripts/health-check.sh http://host.docker.internal:8082'
            }
        }
    }
}
